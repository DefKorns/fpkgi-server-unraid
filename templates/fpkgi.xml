<?xml version="1.0"?>
<Container version="2">
    <Name>fpkgi-server</Name>
    <Repository>ghcr.io/defkorns/fpkgi-server-unraid/fpkgi-server:latest</Repository>
    <Registry>https://github.com/defkorns/fpkgi-server-unraid</Registry>
    <Network>bridge</Network>
    <MyIP/>
    <Shell>bash</Shell>
    <Privileged>false</Privileged>
    <Support/>
    <Project/>
    <ReadMe/>
    <Overview/>
    <Category/>
    <WebUI>http://[IP]:[PORT:8086]</WebUI>
    <TemplateURL/>
    <Icon>https://raw.githubusercontent.com/defkorns/fpkgi-server-unraid/main/icon.png</Icon>
    <ExtraParams/>
    <PostArgs/>
    <CPUset/>
    <DateInstalled/>
    <DonateText/>
    <DonateLink/>
    <Requires/>
    <Config Name="Server Files" Target="/data" Default="/mnt/user/games/ps4" Mode="rw" Description="PKG storage + JSON database" Type="Path" Display="always" Required="true" />
    <Config Name="Server URL" Target="SERVER_URL" Default="http://[UNRAID-IP]:[PORT:8086]" Mode="" Description="HTTP Server Port" Type="Variable" Display="always" Required="true" />
    <Config Name="HTTP Directory" Target="HTTP_DIR" Default="/data" Mode="" Description="HTTP serving directory" Type="Variable" Display="always" Required="true" />
    <Config Name="HTTP PORT" Target="8080" Default="" Mode="tcp" Description="HTTP Server Port" Type="Port" Display="always" Required="false" Mask="false">8086</Config>
    <Config Name="PUID" Target="PUID" Default="1000" Mode="" Description="User ID" Type="Variable" Display="advanced" />
    <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Group ID" Type="Variable" Display="advanced" />
    <Config Name="Timezone" Target="TZ" Default="Europe/Lisbon" Mode="" Description="Timezone" Type="Variable" Display="advanced" />
    <Config Type="Variable" Name="LOG_DEBUG" Target="LOG_DEBUG" Default="0" Description="Enable debug logging (1 = ON, 0 = OFF)" />
    <TailscaleStateDir/>
</Container>
